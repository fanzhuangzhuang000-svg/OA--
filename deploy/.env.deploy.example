# ===== 部署配置环境变量模板 =====
# 复制此文件为 .env.deploy 并填入真实值
# cp .env.deploy.example .env.deploy

# --- 172 测试服务器 ---
DEPLOY_HOST_172=172.20.0.139
DEPLOY_USER_172=ubuntu
# 推荐使用 SSH Key 认证，密码仅作备选
# DEPLOY_PASSWORD_172=your_password_here

# --- 152 展示服务器 ---
DEPLOY_HOST_152=152.136.115.121
DEPLOY_USER_152=ubuntu
# 推荐使用 SSH Key 认证，密码仅作备选
# DEPLOY_PASSWORD_152=your_password_here

# --- SSH 认证方式 ---
# 设置为 'key' 使用 SSH 密钥（推荐），'password' 使用密码
DEPLOY_AUTH_METHOD=key
# SSH 私钥路径（当 auth_method=key 时使用）
DEPLOY_SSH_KEY=~/.ssh/id_rsa

# --- 证书路径（HTTPS 部署用）---
CERT_LOCAL_DIR=./cert_staging/www.afjsw.cn_nginx
CERT_REMOTE_DIR=/etc/nginx/ssl/afjsw.cn
