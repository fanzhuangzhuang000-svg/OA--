# B2.1-5 bonus Laravel logrotate
# 部署: 117 /etc/logrotate.d/oa

/var/www/oa-api/storage/logs/laravel-*.log {
    daily
    missingok
    rotate 14
    compress
    delaycompress
    notifempty
    copytruncate
    create 0640 www-data www-data
    sharedscripts
    postrotate
        # Laravel 写文件用 LOCK_EX, copytruncate 后 fseek 回 0 即可
        # 不需要 reload php-fpm
    endscript
}

/home/nbcy/oa-*.log {
    weekly
    missingok
    rotate 4
    compress
    notifempty
}
